{
  "name": "@hopcoderx/anthropic-auth",
  "version": "1.0.0",
  "description": "HopCoderX Anthropic authentication plugin",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --external @hopcoderx/plugin",
    "prepublishOnly": "bun run build"
  },
  "keywords": ["hopcoderx", "anthropic", "auth", "plugin"],
  "peerDependencies": {
    "@hopcoderx/plugin": "*"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  }
}
