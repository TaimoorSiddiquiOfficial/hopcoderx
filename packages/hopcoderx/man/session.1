.TH HOPCODERX-SESSION 1 "HopCoderX local"
.SH NAME
hopcoderx session \- Session & TUI
.SH SYNOPSIS
.B hopcoderx session
.RI < subcommand >
.RI [ arguments ]
.SH DESCRIPTION
Session & TUI
.SH SUBCOMMANDS
.TP
\fB[project]\fR
Run \(aqhopcoderx session [project] \-\-help\(aq for more information
.TP
\fBattach\fR
Run \(aqhopcoderx session attach \-\-help\(aq for more information
.TP
\fBrun\fR
Run \(aqhopcoderx session run \-\-help\(aq for more information
.TP
\fBsession\fR
Run \(aqhopcoderx session session \-\-help\(aq for more information
.TP
\fBreplay\fR
Run \(aqhopcoderx session replay \-\-help\(aq for more information
.TP
\fBacp\fR
Run \(aqhopcoderx session acp \-\-help\(aq for more information
.SH SEE ALSO
.BR hopcoderx (1)
