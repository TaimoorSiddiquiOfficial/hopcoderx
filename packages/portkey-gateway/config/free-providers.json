{
  "_comment": "bdr-local auto-builds a Portkey load-balance config from individual env vars (OPENROUTER_API_KEY, GROQ_API_KEY, CEREBRAS_API_KEY, TOGETHER_API_KEY, GOOGLE_API_KEY) — no manual base64 needed.",
  "_comment_b": "This file is a reference/documentation. Set the env vars above on Railway and bdr-local will build the config dynamically. Override everything with BDR_PORTKEY_FREE_CONFIG=<base64 JSON>.",
  "strategy": { "mode": "loadbalance" },
  "retry": {
    "attempts": 3,
    "on_status_codes": [429, 500, 502, 503, 504]
  },
  "targets": [
    {
      "provider": "openai",
      "api_key": "YOUR_OPENROUTER_API_KEY",
      "base_url": "https://openrouter.ai/api/v1",
      "override_params": {
        "model": "@preset/hopcoder-free"
      },
      "weight": 3
    },
    {
      "provider": "groq",
      "api_key": "YOUR_GROQ_API_KEY",
      "override_params": { "model": "llama-3.3-70b-versatile" },
      "weight": 2
    },
    {
      "provider": "cerebras",
      "api_key": "YOUR_CEREBRAS_API_KEY",
      "override_params": { "model": "llama3.1-70b" },
      "weight": 2
    },
    {
      "provider": "together-ai",
      "api_key": "YOUR_TOGETHER_API_KEY",
      "override_params": { "model": "Qwen/Qwen2.5-72B-Instruct-Turbo" },
      "weight": 1
    },
    {
      "provider": "google",
      "api_key": "YOUR_GOOGLE_API_KEY",
      "override_params": { "model": "gemini-2.0-flash-exp" },
      "weight": 1
    }
  ]
}
