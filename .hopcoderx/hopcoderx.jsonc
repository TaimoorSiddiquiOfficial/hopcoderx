{
  "$schema": "./config.json",
  "model": "lmstudio/zai-org/glm-4.7-flash",
  "provider": {
    "hopcoderx": {
      "options": {},
    },
    // LM Studio local provider — uses OpenAI-compatible API at localhost:1234
    "lmstudio": {
      "name": "LM Studio",
      "npm": "@ai-sdk/openai-compatible",
      "env": [],
      "options": {
        "baseURL": "http://localhost:1234/v1",
      },
      "models": {
        // Model IDs must match what LM Studio returns from GET /v1/models
        // Only the loaded model will work — load in LM Studio Developer tab first
        "qwen/qwen3-coder-next": {
          "name": "Qwen3 Coder Next (80B MoE A3B)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "limit": { "context": 131072, "output": 8192 },
        },
        "liquid/lfm2.5-1.2b": {
          "name": "LFM2.5 1.2B",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "limit": { "context": 32768, "output": 4096 },
        },
        "nvidia/nemotron-3-nano": {
          "name": "Nemotron 3 Nano (30B MoE A3.5B)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": false,
          "limit": { "context": 131072, "output": 8192 },
        },
        "zai-org/glm-4.6v-flash": {
          "name": "GLM 4.6V Flash (9B Vision)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "limit": { "context": 128000, "output": 8192 },
        },
        "zai-org/glm-4.7-flash": {
          "name": "GLM 4.7 Flash (30B MoE A3B)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": false,
          "limit": { "context": 128000, "output": 8192 },
        },
        "mistralai/devstral-small-2-2512": {
          "name": "Devstral Small 2 (24B)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": true,
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "limit": { "context": 256000, "output": 8192 },
        },
        "mistralai/ministral-3-14b-reasoning": {
          "name": "Ministral 3 14B Reasoning",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "limit": { "context": 256000, "output": 8192 },
        },
      },
    },
  },
  "mcp": {},
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
